datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// Enums
// ==========================================

enum UserRole {
  STUDENT
  ADMIN
}

enum SubmissionStatus {
  PASSED
  FAILED
  PENDING
}

enum RecommendationStatus {
  PENDING
  COMPLETED
}

enum ChatSender {
  USER
  BOT
}

enum ChatPersona {
  TEACHER
  COACH
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  APPROVED
}

enum RecommendationType {
  EXERCISE
  QUIZ
  REVISION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// ==========================================
// User & Auth Management
// ==========================================

model User {
  id               String      @id @default(uuid())
  email            String      @unique
  passwordHash     String
  name             String
  role             UserRole    @default(STUDENT)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  sessions          Session[]
  progress          UserProgress[]
  exerciseSub       UserExerciseSubmission[]
  quizResponses     UserQuizResponse[]
  challengeSub      UserChallengeSubmission[]
  achievements      UserAchievement[]
  certifications    Certification[]
  recommendations   RevisionRecommendation[]
  chatSessions      AIChatSession[]
  projectProgress   UserProjectProgress[]
  streak            UserStreak?
  activityLogs      StudentActivityLog[]
  auditTrails       AuditTrail[]
  promptTemplates   PromptTemplate[]
  aiCodeReviews     AICodeReview[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ==========================================
// Curriculum & Learning Engine
// ==========================================

model Domain {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  orderIndex  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  modules     Module[]

  @@map("domains")
}

model Module {
  id          String   @id @default(uuid())
  domainId    String
  name        String
  description String?
  orderIndex  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  domain      Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  topics      Topic[]

  @@unique([domainId, name])
  @@index([domainId])
  @@map("modules")
}

model Topic {
  id          String   @id @default(uuid())
  moduleId    String
  name        String
  description String?
  orderIndex  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@unique([moduleId, name])
  @@index([moduleId])
  @@map("topics")
}

model Lesson {
  id              String   @id @default(uuid())
  topicId         String
  name            String
  content         String
  orderIndex      Int
  durationMinutes Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  topic            Topic                     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  exercises        Exercise[]
  quizzes          Quiz[]
  challenges       Challenge[]
  userProgress     UserProgress[]
  recommendations  RevisionRecommendation[]
  chatSessions     AIChatSession[]

  @@unique([topicId, name])
  @@index([topicId])
  @@map("lessons")
}

model Exercise {
  id                   String   @id @default(uuid())
  lessonId             String
  title                String
  instructions         String
  startCode            String
  testCode             String
  executionTimeLimitMs Int      @default(5000)
  orderIndex           Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  lesson               Lesson                   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions          UserExerciseSubmission[]

  @@index([lessonId])
  @@map("exercises")
}

model Quiz {
  id            String   @id @default(uuid())
  lessonId      String
  question      String
  options       Json     // Array of answer choices
  correctAnswer String
  explanation   String?
  orderIndex    Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  responses     UserQuizResponse[]

  @@index([lessonId])
  @@map("quizzes")
}

model Challenge {
  id          String   @id @default(uuid())
  lessonId    String
  title       String
  description String
  starterCode String
  testCode    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions UserChallengeSubmission[]

  @@index([lessonId])
  @@map("challenges")
}

// ==========================================
// Student Progress & Submissions
// ==========================================

model UserProgress {
  id           String    @id @default(uuid())
  userId       String
  lessonId     String
  completed    Boolean   @default(false)
  completedAt  DateTime?
  qualityScore Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("user_progress")
}

model UserExerciseSubmission {
  id               String           @id @default(uuid())
  userId           String
  exerciseId       String
  code             String
  status           SubmissionStatus @default(PENDING)
  feedback         String?
  errorOutput      String?
  executionTimeMs  Int?
  createdAt        DateTime         @default(now())

  // Relations
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise         Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([exerciseId])
  @@map("user_exercise_submissions")
}

model UserQuizResponse {
  id             String   @id @default(uuid())
  userId         String
  quizId         String
  selectedOption String
  isCorrect      Boolean
  createdAt      DateTime @default(now())

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@map("user_quiz_responses")
}

model UserChallengeSubmission {
  id             String           @id @default(uuid())
  userId         String
  challengeId    String
  code           String
  status         SubmissionStatus @default(PENDING)
  score          Float?
  createdAt      DateTime         @default(now())

  // Relations
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge      Challenge        @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  aiReviews      AICodeReview[]

  @@index([userId])
  @@index([challengeId])
  @@map("user_challenge_submissions")
}

model RevisionRecommendation {
  id                 String               @id @default(uuid())
  userId             String
  lessonId           String
  conceptName        String
  reason             String
  recommendationType RecommendationType   @default(REVISION)
  status             RecommendationStatus @default(PENDING)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Relations
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson             Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
  @@map("revision_recommendations")
}

// ==========================================
// Gamification & Graduation
// ==========================================

model Achievement {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  badgeUrl    String?
  criteria    Json     // Rule parameters to unlock
  createdAt   DateTime @default(now())

  // Relations
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("user_achievements")
}

model Certification {
  id              String   @id @default(uuid())
  userId          String
  courseName      String
  issuedAt        DateTime @default(now())
  certificateHash String   @unique

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("certifications")
}

// ==========================================
// AI Orchestration & Mentorship
// ==========================================

model AIChatSession {
  id                 String           @id @default(uuid())
  userId             String
  lessonId           String?
  projectMilestoneId String?
  chatType           ChatPersona
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relations
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson             Lesson?          @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  projectMilestone   ProjectMilestone? @relation(fields: [projectMilestoneId], references: [id], onDelete: SetNull)
  messages           AIChatMessage[]

  @@index([userId])
  @@index([lessonId])
  @@index([projectMilestoneId])
  @@map("ai_chat_sessions")
}

model AIChatMessage {
  id              String      @id @default(uuid())
  chatSessionId   String
  sender          ChatSender
  persona         ChatPersona
  content         String
  tokenCount      Int?
  variablesUsed   Json?       // Snapshot of prompt variables injected
  createdAt       DateTime    @default(now())

  // Relations
  chatSession     AIChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
  @@map("ai_chat_messages")
}

model AICodeReview {
  id                     String                  @id @default(uuid())
  userId                 String
  challengeSubmissionId  String
  scoreCorrectness       Float
  scoreReadability       Float
  scoreSecurity          Float
  scorePerformance       Float
  feedbackSummary        String
  reviewerComments       Json                    // JSON list of specific code-line comments
  createdAt              DateTime                @default(now())

  // Relations
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeSubmission    UserChallengeSubmission @relation(fields: [challengeSubmissionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([challengeSubmissionId])
  @@map("ai_code_reviews")
}

model AICache {
  id          String   @id @default(uuid())
  promptHash  String   @unique
  response    String
  modelUsed   String
  tokenCount  Int?
  usageCount  Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([promptHash])
  @@map("ai_caches")
}

// ==========================================
// Industry Projects
// ==========================================

model IndustryProject {
  id                    String   @id @default(uuid())
  name                  String   @unique
  description           String
  repositoryTemplateUrl String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  milestones            ProjectMilestone[]

  @@map("industry_projects")
}

model ProjectMilestone {
  id                   String                @id @default(uuid())
  projectId            String
  title                String
  description          String
  orderIndex           Int
  prTemplate           String?
  filesToModify        Json                  // Expected list of files
  requiredPrerequisites Json                 // List of prerequisite lesson/milestone IDs
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  // Relations
  project              IndustryProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userProgress         UserProjectProgress[]
  chatSessions         AIChatSession[]

  @@unique([projectId, title])
  @@index([projectId])
  @@map("project_milestones")
}

model UserProjectProgress {
  id            String        @id @default(uuid())
  userId        String
  milestoneId   String
  status        ProjectStatus @default(NOT_STARTED)
  repositoryUrl String?
  commitHash    String?
  branchName    String?
  coachFeedback String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone     ProjectMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([userId, milestoneId])
  @@index([userId])
  @@index([milestoneId])
  @@map("user_project_progress")
}

// ==========================================
// Analytics & Streaks
// ==========================================

model UserStreak {
  id               String   @id @default(uuid())
  userId           String   @unique
  streakCount      Int      @default(0)
  lastActivityDate DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model StudentActivityLog {
  id        String   @id @default(uuid())
  userId    String
  eventType String   // e.g. PAGE_VIEW, EXERCISE_RUN, CHAT_MESSAGE
  metadata  Json?    // Context-dependent JSON metadata
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@map("student_activity_logs")
}

// ==========================================
// Administration & Auditing
// ==========================================

model AuditTrail {
  id           String      @id @default(uuid())
  actorId      String
  action       AuditAction
  targetEntity String      // Name of table
  targetId     String      // Primary key of row
  oldValues    Json?
  newValues    Json?
  ipAddress    String?
  createdAt    DateTime    @default(now())

  // Relations
  actor        User        @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([targetEntity, targetId])
  @@map("audit_trails")
}

model PromptTemplate {
  id                String   @id @default(uuid())
  name              String   @unique
  systemInstruction String
  templateText      String
  version           String
  isActive          Boolean  @default(true)
  updatedById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  updatedBy         User     @relation(fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([updatedById])
  @@map("prompt_templates")
}
